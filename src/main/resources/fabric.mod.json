{
	"schemaVersion": 1,
	"id": "chunkup",
	"version": "${version}",
	"name": "Chunkup",
	"description": "Chunkup 是一个面向 Minecraft 1.20.1 (Fabric) 的 GPU 区块生成加速模组，提供 CUDA/OpenCL 密度生成批处理与可选地表构建路径，在保证与原版世界生成兼容的前提下提升新区块生成效率。",
	"authors": [
		"FORGE24"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "Apache-2.0",
	"icon": "assets/chunkup/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "cn.sanrolnet.chunkup.Chunkup",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "cn.sanrolnet.chunkup.client.ChunkupClient",
				"adapter": "kotlin"
			}
		],
		"modmenu": [
			{
				"value": "cn.sanrolnet.chunkup.client.settings.ChunkupModMenuIntegration",
				"adapter": "kotlin"
			}
		],
		"fabric-datagen": [
			{
				"value": "cn.sanrolnet.chunkup.client.ChunkupDataGenerator",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"chunkup.mixins.json",
		{
			"config": "chunkup.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	},
	"suggests": {
		"sodium": "*",
		"modmenu": "*"
	}
}